{
  "name": "log-alert",
  "version": "1.0.0",
  "description": "日志结构化解析与智能告警规则引擎",
  "main": "dist/cli/index.js",
  "bin": {
    "log-alert": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "dev:api": "ts-node src/cli/index.ts serve",
    "dev:panel": "cd panel && streamlit run app.py",
    "test": "jest --config jest.config.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "log",
    "alert",
    "grok",
    "kafka",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "cron-parser": "^5.5.0",
    "fastify": "^4.25.2",
    "glob": "^10.3.10",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.0",
    "kafkajs": "^2.2.4",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.44",
    "tail": "^2.2.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/tail": "^2.2.3",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
